    def handle_thumb(self, parsed):
        parts = parsed.path.split("/")
        if len(parts) < 4: return self.send_error(404)
        
        vid_id = parts[2]
        try: idx = int(parts[3].replace(".jpg", ""))
        except: return self.send_error(400)
        
        q = parse_qs(parsed.query)
        mode = q.get("mode", [self.def_mode])[0]
        try: val = float(q.get("value", [self.def_val])[0])
        except: val = self.def_val
        try: width = int(q.get("width", [self.def_width])[0])
        except: width = self.def_width
        
        if width > 1920: width = 1920
        if width < 100: width = 640

        try:
            path = b64file_decode(vid_id)
        except: return self.send_error(404)

        key = (str(path), idx, mode, val, width)
        cached = IMG_CACHE.get(key)
        if cached:
            return self.send_content(cached, "image/jpeg")

        try:
            entry = next((x for x in self.INDEX.entries if str(x['path']) == str(path)), None)
            if not entry:
                meta = get_extended_metadata(path)
            else:
                meta = entry['meta']
            
            if not meta or idx >= len(meta['chapters']):
                 return self.send_error(404)

            ch = meta['chapters'][idx]
            ts = ts_for_chapter(ch, mode, val)
            
            img_data = render_thumb(path, ts, width)
            IMG_CACHE.put(key, img_data)
            return self.send_content(img_data, "image/jpeg")

        except Exception as e:
            return self.send_error(500)

    def handle_video_stream(self, path_str):
        try:
            vid_id = path_str.split("/")[-1]
            fpath = b64file_decode(vid_id)
        except: return self.send_error(404)

        if not fpath.exists(): return self.send_error(404)
        return self.serve_file_range(fpath)

    def serve_file_range(self, path):
        stat = path.stat()
        file_size = stat.st_size
        range_header = self.headers.get("Range")
        
        start, end = 0, file_size - 1
        if range_header:
            s, e = range_header.replace("bytes=", "").split("-")
            start = int(s) if s else 0
            end = int(e) if e else file_size - 1
        
        length = end - start + 1
        
        try:
            f = open(path, "rb")
            f.seek(start)
        except:
            return self.send_error(404)

        self.send_response(206 if range_header else 200)
        self.send_header("Content-Type", mimetypes.guess_type(path)[0] or "application/octet-stream")
        self.send_header("Content-Length", str(length))
        self.send_header("Content-Range", f"bytes {start}-{end}/{file_size}")
        self.send_header("Accept-Ranges", "bytes")
        self.end_headers()
        
        try:
            remaining = length
            while remaining > 0:
                chunk_size = min(64*1024, remaining)
                data = f.read(chunk_size)
                if not data: break
                self.wfile.write(data)
                remaining -= len(data)
        except: pass
        finally:
            f.close()

    def send_content(self, data, ctype):
        try:
            self.send_response(200)
            self.send_header("Content-Type", ctype)
            self.send_header("Content-Length", str(len(data)))
            self.end_headers()
            self.wfile.write(data)
        except: pass

def main():
    parser = argparse.ArgumentParser(description="VidDeck: Enhanced Video Chapter Thumbnails")
    parser.add_argument("path", nargs="?", default=".", help="Root directory to scan")
    parser.add_argument("--port", type=int, default=8765, help="Port to bind (8765)")
    parser.add_argument("--host", default="0.0.0.0", help="Host to bind (0.0.0.0)")
    args = parser.parse_args()

    root = Path(args.path).resolve()
    if not root.exists():
        print(f"Error: {root} does not exist.")
        sys.exit(1)

    print(f"Scanning {root} for videos...")
    idx = VideoIndex(root)
    Handler.INDEX = idx
    Handler.def_mode = "percent"
    Handler.def_val = 50.0
    Handler.def_width = 1280

    server = ThreadingHTTPServer((args.host, args.port), Handler)
    print(f"\nStarted VidDeck at http://{args.host}:{args.port}")
    print(f"Loaded {len(idx.entries)} videos.")
    print("Press Ctrl+C to stop.")
    
    try:
        server.serve_forever()
    except KeyboardInterrupt:
        print("\nStopped.")

if __name__ == "__main__":
    main()
