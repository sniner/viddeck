# -------------------- Utility --------------------
def b64file(p: Path) -> str:
    return base64.urlsafe_b64encode(str(p.resolve()).encode()).decode()

def b64file_decode(s: str) -> Path:
    return Path(base64.urlsafe_b64decode(s.encode()).decode())

def clamp(x: float, lo: float, hi: float) -> float:
    return max(lo, min(hi, x))

def human_ts(sec: float) -> str:
    m = int((sec % 3600) // 60)
    s = sec % 60
    h = int(sec // 3600)
    return f"{h:02d}:{m:02d}:{s:02.0f}" if h else f"{m:02d}:{s:02.0f}"

def human_size(size_bytes: int) -> str:
    if not size_bytes: return "0 B"
    for unit in ['B', 'KB', 'MB', 'GB']:
        if size_bytes < 1024:
            return f"{size_bytes:.1f} {unit}"
        size_bytes /= 1024
    return f"{size_bytes:.1f} TB"

def run_ffprobe_json(args):
    """Run ffprobe with json output."""
    cmd = ["ffprobe", "-v", "error", "-print_format", "json", *args]
    p = subprocess.run(cmd, text=True, capture_output=True)
    if p.returncode != 0:
        raise RuntimeError(p.stderr)
    return json.loads(p.stdout or "{}")

def get_extended_metadata(path: Path):
    """Extract dict with duration, size, resolution, fps, chapters."""
    cmd = [
        "-show_entries", "format=duration,size,bit_rate",
        "-show_entries", "stream=width,height,avg_frame_rate,codec_name",
        "-select_streams", "v:0", 
        "-show_chapters",
        str(path)
    ]
    
    try:
        data = run_ffprobe_json(cmd)
    except Exception:
        return None

    # Common Format Info
    fmt = data.get("format", {})
    try: duration = float(fmt.get("duration", 0.0))
    except: duration = 0.0
    
    try: size = int(fmt.get("size", 0))
    except: size = 0

    # Stream Info (Video)
    streams = data.get("streams", [])
    width, height, fps_str, codec = 0, 0, "", ""
    if streams:
        v = streams[0]
        width = v.get("width", 0)
        height = v.get("height", 0)
        fps_str = v.get("avg_frame_rate", "0/0")
        codec = v.get("codec_name", "unknown")

    # Calculate float FPS
    fps = 0.0
    if "/" in fps_str:
        try:
            num, den = map(float, fps_str.split("/"))
            if den > 0: fps = num / den
        except: pass
    else:
        try: fps = float(fps_str)
        except: pass

    # Chapters
    chapters = []
    for ch in data.get("chapters", []) or []:
        try:
            s_t = float(ch.get("start_time", 0.0))
            e_t = float(ch.get("end_time", s_t))
        except: continue
        
        tags = ch.get("tags") or {}
        title = tags.get("title") or tags.get("TITLE") or ""
        chapters.append({
            "start": s_t,
            "end": max(e_t, s_t),
            "title": title
        })
    
    # Sort
    chapters.sort(key=lambda x: x["start"])
    
    if not chapters and duration > 0:
        chapters.append({"start": 0.0, "end": duration, "title": ""})

    for i in range(len(chapters)-1):
        if chapters[i]["end"] <= chapters[i]["start"]:
             chapters[i]["end"] = max(chapters[i+1]["start"] - 0.1, chapters[i]["start"])

    return {
        "duration": duration,
        "size": size,
        "width": width,
        "height": height,
        "fps": fps,
        "codec": codec,
        "chapters": chapters
    }

def ts_for_chapter(ch, mode: str, value: float) -> float:
    length = max(0.01, ch["end"] - ch["start"])
    if mode == "seconds":
        t = ch["start"] + value
    else:
        p = clamp(value, 0.0, 100.0)/100.0
        t = ch["start"] + p*length
    return clamp(t, ch["start"], ch["end"])

def render_thumb(path: Path, ts: float, width: int) -> bytes:
    # Helper to run ffmpeg
    def run(t):
        cmd = [
            "ffmpeg", "-v", "error",
            "-ss", f"{t:.3f}",
            "-i", str(path),
            "-frames:v", "1",
            "-vf", f"scale={width}:-2",
            "-f", "image2pipe", "-vcodec", "mjpeg", "pipe:1"
        ]
        return subprocess.run(cmd, stdout=subprocess.PIPE, stderr=subprocess.PIPE)

    p = run(ts)
    
    if p.returncode != 0 or len(p.stdout) == 0:
        p = run(0.0)
        if p.returncode != 0 or len(p.stdout) == 0:
             cmd = [
                "ffmpeg", "-v", "error",
                "-i", str(path),
                "-frames:v", "1",
                "-vf", f"scale={width}:-2",
                "-f", "image2pipe", "-vcodec", "mjpeg", "pipe:1"
             ]
             p = subprocess.run(cmd, stdout=subprocess.PIPE, stderr=subprocess.PIPE)
             if p.returncode != 0 or len(p.stdout) == 0:
                 raise RuntimeError(f"ffmpeg error: {p.stderr.decode(errors='ignore')}")

    return p.stdout

# -------------------- App State & Index --------------------
class LRU:
    def __init__(self, max_items=256):
        self.max = max_items
        self.d = OrderedDict()
    def get(self, key):
        v = self.d.get(key)
        if v: self.d.move_to_end(key)
        return v
    def put(self, key, val):
        self.d[key] = val
        self.d.move_to_end(key)
        if len(self.d) > self.max: self.d.popitem(last=False)

IMG_CACHE = LRU(max_items=512)

import threading

class VideoIndex:
    def __init__(self, root: Path):
        self.root = root
        self.entries = []
        self.scanning = True
        self.count = 0
        
        # Start background scan
        self.thread = threading.Thread(target=self._scan_worker, daemon=True)
        self.thread.start()

    def _scan_worker(self):
        files = []
        for pat in VIDEO_PATTERNS:
            files.extend(self.root.rglob(pat))
        files = sorted(set(files))
        
        out = []
        for f in files:
            if f.name.startswith('.'): continue
            try:
                meta = get_extended_metadata(f)
                if meta and meta["duration"] > 0:
                    out.append({
                        "id": b64file(f),
                        "path": f,
                        "rel_path": f.relative_to(self.root),
                        "meta": meta
                    })
                    self.count += 1
            except Exception:
                continue
        
        self.entries = out
        self.scanning = False

    def rename_file(self, old_id, new_name):
        try:
            old_path = b64file_decode(old_id)
            if not old_path.exists():
                raise FileNotFoundError("Original file not found")
            
            # Treat new_name as relative to root
            new_path = (self.root / new_name).resolve()
            
            # Security check: ensure new_path is inside root
            if not str(new_path).startswith(str(self.root)):
                 raise ValueError("Path traversal not allowed")

            if new_path.exists():
                raise FileExistsError("File with this name already exists")
            
            # Ensure parent dir exists
            new_path.parent.mkdir(parents=True, exist_ok=True)
            
            os.rename(old_path, new_path)
            
            # Update index
            for entry in self.entries:
                if entry['id'] == old_id:
                    entry['path'] = new_path
                    entry['rel_path'] = new_path.relative_to(self.root)
                    entry['id'] = b64file(new_path)
                    break
            return True
        except Exception as e:
            raise e

# -------------------- HTTP Server --------------------
class ThreadingHTTPServer(ThreadingMixIn, HTTPServer):
    daemon_threads = True

class Handler(BaseHTTPRequestHandler):
    INDEX: VideoIndex = None
    # Defaults
    def_mode = "percent"
    def_val = 50.0
    def_width = 1280

    def do_GET(self):
        try:
            parsed = urlparse(self.path)
            path = parsed.path
            
            if path == "/":
                return self.render_index(parsed)
            elif path == "/style.css":
                return self.send_content(STYLESHEET.encode(), "text/css")
            elif path == "/script.js":
                return self.send_content(JAVASCRIPT.encode(), "application/javascript")
            elif path.startswith("/thumb/"):
                return self.handle_thumb(parsed)
            elif path.startswith("/video/"):
                return self.handle_video_stream(path)
            else:
                return self.send_error(404)
        except Exception as e:
            self.send_error(500, str(e))

    def do_POST(self):
        parsed = urlparse(self.path)
        qs = parse_qs(parsed.query)
        # Parse body for POST data if needed, but here we use urlencoded body or qs mixed usually.
        # But fetch uses body. Simple parse_qs on body for standardization:
        content_len = int(self.headers.get('Content-Length', 0))
        post_body = self.rfile.read(content_len).decode('utf-8')
        post_qs = parse_qs(post_body)
        
        # Merge queries
        qs.update(post_qs)

        if parsed.path.startswith("/api/open_file"):
            self.api_open(qs, folder=False)
        elif parsed.path.startswith("/api/open_dir"):
            self.api_open(qs, folder=True)
        elif parsed.path.startswith("/api/rename"):
            self.api_rename(qs)
        else:
            self.send_error(404)

    def api_rename(self, qs):
        fid = qs.get("id", [None])[0]
        new_name = qs.get("new_name", [None])[0]
        
        if not fid or not new_name:
            return self.send_error(400, "Missing id or new_name")
            
        try:
            self.INDEX.rename_file(fid, new_name)
            self.send_content(b"OK", "text/plain")
        except Exception as e:
            self.send_error(500, str(e))

    def api_open(self, qs, folder=False):
        fid = qs.get("id", [None])[0]
        if not fid: return self.send_error(400)
        try:
            path = b64file_decode(fid)
            target = str(path.parent) if folder else str(path)
            
            if sys.platform == "darwin":
                cmd = ["open", target] if folder else ["open", target]
            elif sys.platform == "win32":
                cmd = ["explorer", target]
            else: # linux
                cmd = ["xdg-open", target]
            
            subprocess.Popen(cmd)
            self.send_content(b"OK", "text/plain")
        except Exception as e:
            self.send_error(500, str(e))

